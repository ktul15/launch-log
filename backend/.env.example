# Server
NODE_ENV=development
PORT=3001

# Database (matches docker-compose.yml)
# Add ?connection_limit=10&pool_timeout=10 to cap the connection pool in production
DATABASE_URL=postgresql://launchlog:launchlog@localhost:5433/launchlog_dev
# WARNING: change the password above before deploying to any non-local environment

# Redis (matches docker-compose.yml)
REDIS_URL=redis://:launchlog@localhost:6379
# WARNING: change the password above before deploying to any non-local environment

# JWT — generate with: openssl rand -base64 48
# These placeholders are intentionally too short to pass startup validation,
# forcing you to set real secrets before the server will start.
JWT_SECRET=CHANGEME
JWT_REFRESH_SECRET=CHANGEME
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — origin(s) allowed to call the API (comma-separated in production)
CORS_ORIGIN=http://localhost:3000

# Email (Resend) — required in notifications issue
# RESEND_API_KEY=

# Stripe — required in billing issue
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Cloudflare R2 — required in file upload issue
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_ENDPOINT=

# Google OAuth — required in auth issue (#3)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
