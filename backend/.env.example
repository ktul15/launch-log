# ────────────────────────────────────────────────
#  LaunchLog — Backend Environment Variables
#  Copy this file to .env and fill in the values.
#  cp .env.example .env
# ────────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3001
# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Database ─────────────────────────────────────
# Matches the postgres service in docker-compose.yml
# Note: port 5433 (not 5432) — host port is mapped to avoid collisions
DATABASE_URL=postgresql://launchlog:launchlog@localhost:5433/launchlog_dev

# Docker Compose credentials — override via root-level .env to change both places at once
POSTGRES_USER=launchlog
POSTGRES_PASSWORD=launchlog
POSTGRES_DB=launchlog_dev

# ── Redis ────────────────────────────────────────
# Matches the redis service in docker-compose.yml
# Uses 'default' as username — compatible with both ioredis and node-redis v4+
REDIS_URL=redis://default:launchlog@localhost:6379

# Exposed separately for BullMQ connection options ({ host, port, password })
REDIS_PASSWORD=launchlog

# ── JWT ──────────────────────────────────────────
# REQUIRED: Replace both secrets before running in any real environment.
# Generate secure values with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 characters — the app will refuse to start if these are too short.
JWT_SECRET=CHANGEME
JWT_REFRESH_SECRET=CHANGEME
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────
# Comma-separated list of allowed origins in production
CORS_ORIGIN=http://localhost:3000
# Public URL of this backend — used to build the Google OAuth callback URL.
# Must be registered in Google Cloud Console as an authorised redirect URI.
APP_URL=http://localhost:3001

# ── Email (Resend) ────────────────────────────────
# RESEND_API_KEY=
# FRONTEND_URL=http://localhost:3000
# RESEND_FROM_EMAIL must use a domain verified in your Resend dashboard.
# Using an unverified domain silently fails all notification sends.
# RESEND_FROM_EMAIL=notifications@updates.launchlog.app

# ── Stripe — required in billing issue ───────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── Cloudflare R2 — required in file upload issue ─
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_ENDPOINT=
# R2_PUBLIC_URL=

# ── Google OAuth ─────────────────────────────────
# Callback URL to register in Google Cloud Console:
#   http://localhost:3001/api/v1/auth/google/callback (dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
